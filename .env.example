# ========================================
# 金融资讯问答助手 - 环境配置文件
# ========================================

# ----------------
# 项目基础配置
# ----------------
PROJECT_NAME="金融资讯问答助手"
VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development  # development, testing, production

# ----------------
# 路径配置
# ----------------
# 项目根目录 (请修改为实际路径)
PROJECT_ROOT=/home/your_username/finance-qa-assistant

# 数据目录
DATA_DIR=${PROJECT_ROOT}/data
RAW_DATA_DIR=${DATA_DIR}/raw
PROCESSED_DATA_DIR=${DATA_DIR}/processed
SFT_DATA_DIR=${DATA_DIR}/sft_data

# 模型目录
MODEL_DIR=${PROJECT_ROOT}/models
BASE_MODEL_PATH=${MODEL_DIR}/base/Qwen2.5-7B-Instruct
EMBEDDING_MODEL_PATH=${MODEL_DIR}/embeddings/bge-large-zh-v1.5
RERANKER_MODEL_PATH=${MODEL_DIR}/embeddings/bge-reranker-large
FINETUNED_MODEL_PATH=${MODEL_DIR}/finetuned/finance-qa-v1

# 日志目录
LOG_DIR=${PROJECT_ROOT}/logs

# ----------------
# 向量数据库配置
# ----------------
# Qdrant配置
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=  # 如果使用云服务需要填写

# 集合名称
QDRANT_COLLECTION_NEWS=finance_news
QDRANT_COLLECTION_ANNOUNCEMENT=finance_announcement
QDRANT_COLLECTION_REPORT=finance_report

# 向量维度 (bge-large-zh-v1.5 是 1024)
VECTOR_DIM=1024

# ----------------
# API配置
# ----------------
# OpenAI API (用于SFT数据生成，可选)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# Anthropic API (可选)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ----------------
# 数据采集配置
# ----------------
# 爬虫配置
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=5

# 代理配置 (如果需要)
HTTP_PROXY=
HTTPS_PROXY=

# 数据限制
MAX_NEWS_PER_DAY=10000
MAX_ANNOUNCEMENTS_PER_DAY=5000

# ----------------
# RAG检索配置
# ----------------
# 检索参数
TOP_K=5  # 返回前K个结果
RERANK_TOP_K=10  # 重排前取前K个
BM25_WEIGHT=0.3  # BM25权重
VECTOR_WEIGHT=0.7  # 向量检索权重

# 分块参数
CHUNK_SIZE=512  # 文本块大小
CHUNK_OVERLAP=50  # 重叠大小

# ----------------
# 模型训练配置
# ----------------
# 训练超参数
BATCH_SIZE=2
GRADIENT_ACCUMULATION_STEPS=8
LEARNING_RATE=5e-5
NUM_EPOCHS=2
WARMUP_RATIO=0.1
WEIGHT_DECAY=0.01

# LoRA配置
LORA_RANK=8
LORA_ALPHA=16
LORA_DROPOUT=0.05
LORA_TARGET_MODULES=all  # all 或指定模块

# 量化配置
QUANTIZATION_BIT=4  # 4-bit量化
LOAD_IN_4BIT=true
BNB_4BIT_COMPUTE_DTYPE=float16

# 训练设备
CUDA_VISIBLE_DEVICES=0  # GPU编号
NUM_GPUS=1

# ----------------
# 推理部署配置
# ----------------
# vLLM配置
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_MODEL_LEN=4096
VLLM_TENSOR_PARALLEL_SIZE=1

# FastAPI配置
API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=4
API_RELOAD=false  # 生产环境设为false

# Streamlit配置
STREAMLIT_HOST=0.0.0.0
STREAMLIT_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# ----------------
# Agent配置
# ----------------
# Agent模式
AGENT_TYPE=react  # react, zero-shot-react, conversational
AGENT_MAX_ITERATIONS=5
AGENT_EARLY_STOPPING_METHOD=force  # force, generate

# 工具超时
TOOL_TIMEOUT=30

# ----------------
# 日志配置
# ----------------
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT={time:YYYY-MM-DD HH:mm:ss} | {level} | {name}:{function}:{line} | {message}
LOG_ROTATION=500 MB
LOG_RETENTION=30 days

# ----------------
# 数据库配置 (可选)
# ----------------
# SQLite配置 (行情数据)
SQLITE_DB_PATH=${DATA_DIR}/market_data.db

# PostgreSQL配置 (如果使用)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=finance_qa
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=your_password_here

# ----------------
# 安全配置
# ----------------
# API Key验证 (生产环境使用)
API_KEY_ENABLED=false
API_KEY=your-secret-api-key

# CORS配置
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8501"]
CORS_ALLOW_CREDENTIALS=true

# ----------------
# 监控配置 (可选)
# ----------------
# Prometheus
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_ENABLED=false
GRAFANA_PORT=3000

# ----------------
# 缓存配置 (可选)
# ----------------
# Redis缓存
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 缓存过期时间 (秒)
CACHE_TTL=3600

# ----------------
# 特性开关
# ----------------
ENABLE_WEB_SEARCH=false
ENABLE_CALCULATOR=true
ENABLE_CODE_EXECUTION=false
ENABLE_FILE_UPLOAD=true

# ----------------
# 实验性功能
# ----------------
ENABLE_AGENTIC_RL=false
ENABLE_MULTIMODAL=false
ENABLE_STREAMING=true

# ========================================
# 注意事项:
# 1. 请勿将此文件提交到Git (已在.gitignore中)
# 2. 敏感信息请妥善保管
# 3. 生产环境请修改所有密码和密钥
# 4. 根据实际硬件调整内存和GPU配置
# ========================================
